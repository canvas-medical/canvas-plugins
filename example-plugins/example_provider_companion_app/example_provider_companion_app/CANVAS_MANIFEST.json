{
    "sdk_version": "0.1.4",
    "plugin_version": "0.0.1",
    "name": "example_provider_companion_app",
    "description": "Example plugin demonstrating provider companion applications at global, patient, and note scope levels.",
    "url_permissions": [
        {
            "url": "https://www.canvasmedical.com/extensions",
            "permissions": ["ALLOW_SAME_ORIGIN", "SCRIPTS", "MICROPHONE", "CAMERA"]
        }
    ],
    "components": {
        "applications": [
            {
                "class": "example_provider_companion_app.applications.my_application:GlobalApp",
                "name": "Global Tool",
                "description": "A companion app available from the main page, not tied to a patient.",
                "scope": "provider_companion_global",
                "icon": "assets/doctor.png"
            },
            {
                "class": "example_provider_companion_app.applications.my_application:PatientApp",
                "name": "Patient Tool",
                "description": "A companion app scoped to a specific patient.",
                "scope": "provider_companion_patient_specific",
                "icon": "assets/doctor.png"
            },
            {
                "class": "example_provider_companion_app.applications.my_application:NoteApp",
                "name": "Note Tool",
                "description": "A companion app scoped to a specific note/encounter.",
                "scope": "provider_companion_note_specific",
                "icon": "assets/doctor.png"
            }
        ],
        "handlers": [
            {
                "class": "example_provider_companion_app.handlers.my_web_app:MyWebApp",
                "description": "Serves the application pages for each scope level.",
                "data_access": {
                    "event": "",
                    "read": [],
                    "write": []
                }
            }
        ],
        "commands": [],
        "content": [],
        "effects": [],
        "views": []
    },
    "variables": [],
    "tags": {},
    "references": [],
    "license": "",
    "diagram": false,
    "readme": "./README.md"
}
